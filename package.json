{
  "name": "savr-action",
  "description": "GitHub Action that keeps draft releases ready so teams can publish manually from the GitHub Releases UI.",
  "version": "0.0.0-development",
  "author": "Fabian Pahl",
  "type": "module",
  "packageManager": "pnpm@10.7.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "ncc build src/index.ts",
    "local-action": "local-action . src/main.ts .env",
    "prepare": "husky",
    "test": "vitest"
  },
  "dependencies": {
    "@actions/core": "3.0.0",
    "@actions/github": "9.0.0",
    "handlebars": "4.7.9",
    "semver": "7.7.4"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/types": "20.5.0",
    "@eslint/js": "10.0.1",
    "@github/local-action": "7.0.1",
    "@types/node": "24.12.0",
    "@types/semver": "7.7.1",
    "@vercel/ncc": "0.38.4",
    "eslint": "10.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prefer-arrow-functions": "3.9.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "package-changed": "3.0.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2",
    "vitest": "4.1.2"
  },
  "pnpm": {
    "overrides": {
      "@octokit/request-error@>=1.0.0 <5.1.1": ">=5.1.1",
      "@octokit/request@>=1.0.0 <8.4.1": ">=8.4.1",
      "@octokit/plugin-paginate-rest@>=1.0.0 <9.2.2": ">=9.2.2",
      "undici@<6.23.0": ">=6.23.0",
      "minimatch@<3.1.3": ">=3.1.3",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "minimatch@<3.1.4": ">=3.1.4",
      "fast-xml-parser@>=5.0.0 <5.3.8": ">=5.3.8",
      "handlebars@<4.7.8": ">=4.7.8",
      "undici@>=7.0.0 <7.24.0": ">=7.24.0",
      "undici@>=6.0.0 <6.24.0": ">=6.24.0",
      "undici@<6.24.0": ">=6.24.0",
      "undici@>=7.17.0 <7.24.0": ">=7.24.0",
      "fast-xml-parser@>=4.0.0-beta.3 <=5.5.5": ">=5.5.6"
    }
  }
}
