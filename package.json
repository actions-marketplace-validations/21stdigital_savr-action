    "@github/local-action": "7.0.1",
    "@types/node": "24.13.2",
    "@types/semver": "7.7.1",
    "@vercel/ncc": "0.44.0",
    "eslint": "10.5.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prefer-arrow-functions": "3.9.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
